---
const base = import.meta.env.BASE_URL
---
<header class="site-header">
  <div class="header-inner container">
    <a href={base} class="header-logo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="24" height="24" rx="6" fill="var(--color-primary)"/>
        <path d="M7 8h10M7 12h7M7 16h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span>edgekit</span>
    </a>
    <nav class="header-nav">
      <a href={`${base}docs/getting-started`}>Docs</a>
      <a href={`${base}demos`}>Demos</a>
      <a href={`${base}use-cases`}>Use Cases</a>
      <a href={`${base}blog`}>Blog</a>
      <a href={`${base}roadmap`}>Roadmap</a>
      <a href="https://github.com/kevinmarmstrong/edgekit" class="header-github">
        <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }
  .header-logo {
    display: flex;
    align-items: center;
    gap: var(--size-sm);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
  }
  .header-logo:hover { text-decoration: none; }
  .header-nav {
    display: flex;
    align-items: center;
    gap: var(--size-lg);
    font-size: 0.9rem;
  }
  .header-nav a {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }
  .header-nav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }
  .header-github {
    display: flex;
    align-items: center;
  }
  @media (max-width: 768px) {
    .header-nav { gap: var(--size-md); font-size: 0.8rem; }
  }
</style>
