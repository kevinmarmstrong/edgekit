---
interface Props {
  title: string
  description: string
  icon?: string
  badge?: 'available' | 'coming' | 'planned'
  href?: string
}

const { title, description, icon, badge = 'available', href } = Astro.props
const Tag = href ? 'a' : 'div'
---
<Tag class="feature-card" href={href}>
  {icon && <span class="feature-icon">{icon}</span>}
  <div>
    <h3>
      {title}
      {badge === 'coming' && <span class="badge badge-coming">Coming Soon</span>}
      {badge === 'planned' && <span class="badge badge-planned">Planned</span>}
    </h3>
    <p>{description}</p>
  </div>
</Tag>

<style>
  .feature-card {
    display: flex;
    gap: var(--size-md);
    padding: var(--size-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    transition: all 0.15s;
    color: inherit;
    text-decoration: none;
  }
  a.feature-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .feature-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }
  .feature-card h3 {
    display: flex;
    align-items: center;
    gap: var(--size-sm);
    font-size: 1rem;
    margin: 0;
  }
  .feature-card p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: var(--size-xs) 0 0;
    line-height: 1.5;
  }
</style>
