---
import Base from './Base.astro'

interface Props {
  title: string
  description?: string
  date?: string
  author?: string
}

const { title, description, date, author = 'edgekit team' } = Astro.props
---
<Base title={title} description={description}>
  <main class="blog-main">
    <article class="blog-article">
      {date && <time class="blog-date">{date}</time>}
      <h1>{title}</h1>
      {author && <p class="blog-author">By {author}</p>}
      <div class="blog-body">
        <slot />
      </div>
    </article>
  </main>
</Base>

<style>
  .blog-main {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--size-2xl) var(--size-lg);
  }
  .blog-date {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
  .blog-article h1 {
    margin-top: var(--size-sm);
  }
  .blog-author {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--size-xl);
  }
  .blog-body {
    font-size: 1.05rem;
    line-height: 1.75;
  }
</style>
