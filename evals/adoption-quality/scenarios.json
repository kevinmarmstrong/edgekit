{
  "version": "edgekit.adoption-quality-scenarios.v1",
  "description": "Outcome-grade prompts for proving EdgeKit answers are useful to developers adopting an in-app agent, not just successful docs search calls.",
  "scenarios": [
    {
      "id": "add-agent-to-app",
      "surface": "docs-qa",
      "prompt": "how will this help me add an agent to my app?",
      "required": [
        { "category": "directness", "label": "answers the adoption question directly", "pattern": "\\b(add|embed|drop|install|wire)\\b[\\s\\S]{0,120}\\b(agent|sidecar|edge-chat)\\b" },
        { "category": "integration", "label": "names the web component", "pattern": "<edge-chat>|EdgeChat" },
        { "category": "integration", "label": "names tool registration", "pattern": "registerTools|register existing app|typed tools" },
        { "category": "architecture", "label": "preserves host-owned app state", "pattern": "host app[\\s\\S]{0,120}(owns|keeps|enforces)[\\s\\S]{0,120}(state|auth|business logic|permissions)" },
        { "category": "value", "label": "connects to local browser execution", "pattern": "Chrome AI|WebLLM|browser-local|browser-native|local-first" },
        { "category": "safety", "label": "mentions approval for risky work", "pattern": "approval|needsApproval|gated mutation" }
      ],
      "forbidden": [
        { "category": "directness", "label": "does not dump stock docs sections", "pattern": "^(North Star|Latency and Resilience|Workflow Harness|Packages):" },
        { "category": "transparency", "label": "does not sell as SaaS pricing", "pattern": "book a demo|contact sales|pricing tier" }
      ]
    },
    {
      "id": "first-integration-step",
      "surface": "site-assistant",
      "prompt": "what do I add first to my app?",
      "required": [
        { "category": "directness", "label": "starts with the first implementation move", "pattern": "\\b(first|start|begin)\\b[\\s\\S]{0,140}<edge-chat>|<edge-chat>[\\s\\S]{0,140}\\b(first|start|begin)\\b" },
        { "category": "integration", "label": "includes configure step", "pattern": "\\.configure\\(|configure" },
        { "category": "integration", "label": "includes registerTools step", "pattern": "registerTools" },
        { "category": "architecture", "label": "does not move business logic into the assistant", "pattern": "existing app|host app|business logic" }
      ],
      "forbidden": [
        { "category": "directness", "label": "does not answer with demo list", "pattern": "Ecommerce retrofit[\\s\\S]+Mission control" }
      ]
    },
    {
      "id": "chatbot-difference",
      "surface": "docs-qa",
      "prompt": "how is edgekit different from embedding a chatbot?",
      "required": [
        { "category": "directness", "label": "contrasts sidecar with chatbot", "pattern": "chatbot[\\s\\S]{0,180}(sidecar|tool|workflow)|sidecar[\\s\\S]{0,180}chatbot" },
        { "category": "architecture", "label": "mentions app-owned tools or state", "pattern": "app-owned|host app|registered tools|existing app" },
        { "category": "integration", "label": "mentions in-workflow actions", "pattern": "tool|action|CTA|form|approval" }
      ],
      "forbidden": [
        { "category": "directness", "label": "does not only define browser-native runtime", "pattern": "^edgekit is a browser-native agent runtime\\." }
      ]
    },
    {
      "id": "unsafe-database-update",
      "surface": "site-assistant",
      "prompt": "can the agent update my database directly if I give it my JWT?",
      "required": [
        { "category": "safety", "label": "rejects putting JWTs in prompt", "pattern": "No|Do not|Don't" },
        { "category": "safety", "label": "keeps credentials in execution context", "pattern": "tool execution context|sessionProvider|identityProvider|backend|server" },
        { "category": "architecture", "label": "keeps permission enforcement in host app", "pattern": "host app[\\s\\S]{0,160}(permission|authorization|RBAC|auth)|RBAC" },
        { "category": "safety", "label": "requires approvals/audit for risky mutations", "pattern": "approval|audit|gated" }
      ],
      "forbidden": [
        { "category": "safety", "label": "does not encourage prompt secrets", "pattern": "put (your )?JWT|paste (your )?token|include (your )?cookie" }
      ]
    },
    {
      "id": "token-cost-value",
      "surface": "docs-qa",
      "prompt": "why would I use this instead of paying cloud tokens for every user message?",
      "required": [
        { "category": "value", "label": "explains variable cost problem", "pattern": "variable|unbounded|per-message|per user|token" },
        { "category": "value", "label": "explains local compute path", "pattern": "Chrome AI|WebLLM|browser|local" },
        { "category": "architecture", "label": "says cloud fallback is explicit", "pattern": "fallbacks?[\\s\\S]{0,160}(explicit|configurable|developer-provided)|(explicit|configurable|developer-provided)[\\s\\S]{0,160}fallbacks?|explicit[\\s\\S]{0,120}cloud" }
      ],
      "forbidden": [
        { "category": "transparency", "label": "does not claim cloud is never possible", "pattern": "never uses cloud|cloud is impossible" }
      ]
    },
    {
      "id": "agentic-not-rag",
      "surface": "site-assistant",
      "prompt": "is edgekit just fallback search or RAG, or can it actually enable agentic workflows in my app?",
      "required": [
        { "category": "directness", "label": "answers that EdgeKit is not just search/RAG", "pattern": "not just|not only|more than[\\s\\S]{0,120}(search|RAG|docs)" },
        { "category": "integration", "label": "names registered app tools", "pattern": "registerTools|registered tools|typed tools" },
        { "category": "integration", "label": "names workflow UI actions", "pattern": "registerActions|CTA|form|EdgeView|AG-UI|action" },
        { "category": "architecture", "label": "names state hydration or current app context", "pattern": "stateProvider|state hydration|current app state|workflow context|page context" },
        { "category": "safety", "label": "names approval gated mutations", "pattern": "approval|needsApproval|gated mutation" },
        { "category": "architecture", "label": "keeps execution app-owned", "pattern": "host app[\\s\\S]{0,160}(owns|executes|keeps|enforces)|app-owned" }
      ],
      "forbidden": [
        { "category": "directness", "label": "does not reduce EdgeKit to docs search", "pattern": "EdgeKit is (a )?(docs search|RAG|search-only)" }
      ]
    },
    {
      "id": "vibe-coder-first-sidecar",
      "surface": "site-assistant",
      "prompt": "I am using an AI coding agent. How do I add a production-grade sidecar to my app with edgekit?",
      "required": [
        { "category": "integration", "label": "mentions Mission Profile", "pattern": "Mission Profile" },
        { "category": "integration", "label": "mentions Skills", "pattern": "Skills" },
        { "category": "integration", "label": "mentions edge-chat", "pattern": "<edge-chat>|EdgeChat" },
        { "category": "integration", "label": "mentions registered app tools", "pattern": "registerTools|registered tools|typed tools" },
        { "category": "architecture", "label": "keeps app ownership boundary", "pattern": "host app|app-owned|existing app" },
        { "category": "safety", "label": "mentions approval gates", "pattern": "approval|needsApproval|gated" },
        { "category": "testing", "label": "mentions outcome testing", "pattern": "outcome|harness|research|eval" }
      ],
      "forbidden": [
        { "category": "directness", "label": "does not answer with demo list", "pattern": "Ecommerce retrofit[\\s\\S]+Mission control" }
      ]
    },
    {
      "id": "starter-new-mission",
      "surface": "site-assistant",
      "prompt": "what starter should my coding agent use to create a new production-grade mission?",
      "required": [
        { "category": "integration", "label": "points to concrete starter profile", "pattern": "docs/templates/mission-profile-starter/profile\\.ts|support-workflow" },
        { "category": "integration", "label": "mentions Skills and Mission Profile", "pattern": "Skills?[\\s\\S]{0,160}Mission Profile|Mission Profile[\\s\\S]{0,160}Skills?" },
        { "category": "architecture", "label": "says to replace tool executes with app APIs", "pattern": "replace[\\s\\S]{0,120}(execute|app APIs|app-owned)" },
        { "category": "testing", "label": "names validation", "pattern": "validateMissionProfile" },
        { "category": "testing", "label": "names outcome scenarios", "pattern": "harness-scenarios\\.json|outcome scenarios" },
        { "category": "safety", "label": "keeps ticket creation approval gated", "pattern": "approval|rejection preserves state" }
      ],
      "forbidden": [
        { "category": "directness", "label": "does not tell adopter to start from a blank template", "pattern": "blank template|empty template" }
      ]
    },
    {
      "id": "knowledge-access-modularity",
      "surface": "site-assistant",
      "prompt": "what is the scalable approach for RAG, vector search, GraphRAG, citations, and dynamic knowledge bases?",
      "required": [
        { "category": "directness", "label": "frames retrieval as Knowledge Access Skills", "pattern": "Knowledge Access Skills|retrieval[\\s\\S]{0,120}Skill" },
        { "category": "integration", "label": "names Edgekit knowledge contracts", "pattern": "EdgeKnowledgeSource|createKnowledgeTool|createKnowledgeSkill" },
        { "category": "architecture", "label": "says Edgekit does not own the vector or graph engine", "pattern": "Do not put|does not own|not.*built-in RAG|vector database|graph engine" },
        { "category": "integration", "label": "names recommended ecosystem options", "pattern": "LlamaIndex|LangChain|Qdrant|Neo4j|GraphRAG" },
        { "category": "safety", "label": "keeps retrieval permissioning app-owned", "pattern": "host app[\\s\\S]{0,160}(permission|authorization|owns|filtering)|permission filtering" },
        { "category": "testing", "label": "mentions citations or freshness in outcome tests", "pattern": "citations?|freshness|stale|outcome tests|source facts" }
      ],
      "forbidden": [
        { "category": "architecture", "label": "does not say Edgekit ships its own RAG database", "pattern": "EdgeKit ships (a )?(vector database|graph database|RAG database)" }
      ]
    },
    {
      "id": "agent-adoption-kit-recipes",
      "surface": "site-assistant",
      "prompt": "do you provide coding-agent skills and recipes for an Astro intake pipeline with a knowledge base?",
      "required": [
        { "category": "directness", "label": "answers with the Adoption Kit", "pattern": "Adoption Kit" },
        { "category": "integration", "label": "names coding-agent skills", "pattern": "SKILL\\.md|edgekit-implementer|edgekit-outcome-tester|edgekit-security-review" },
        { "category": "integration", "label": "names recipe scaffolding", "pattern": "edgekit-init|astro-intake-knowledge|recipes?" },
        { "category": "integration", "label": "names Astro intake plus knowledge path", "pattern": "Astro[\\s\\S]{0,160}(Knowledge Access|intake)|astro-intake-knowledge" },
        { "category": "architecture", "label": "keeps recipes additive instead of core clutter", "pattern": "recipes?[\\s\\S]{0,180}(core|quick start|scalable|grow)|scalable direction" },
        { "category": "safety", "label": "keeps intake app-owned and approval gated", "pattern": "approval-gated|approval[\\s\\S]{0,120}app-owned|app-owned tool" }
      ],
      "forbidden": [
        { "category": "architecture", "label": "does not turn recipes into a separate hosted runtime", "pattern": "hosted recipe runtime|recipes replace Edgekit core" }
      ]
    },
    {
      "id": "public-site-qa-install",
      "surface": "site-assistant",
      "prompt": "I want to add elegant Q&A to my personal website. What Edgekit path should my coding agent use?",
      "required": [
        { "category": "integration", "label": "uses grounded Q&A primitive", "pattern": "createGroundedQaSkill|grounded public-site Q&A|public-site Q&A" },
        { "category": "integration", "label": "uses lite UI import", "pattern": "@kevinmarmstrong/edgekit-ui/lite|lite" },
        { "category": "safety", "label": "requires strict grounding", "pattern": "grounding[\\s\\S]{0,40}strict|strict grounding" },
        { "category": "identity", "label": "configures assistant identity", "pattern": "agentIdentity|assistant identity" },
        { "category": "fallback", "label": "uses same evidence path for no model", "pattern": "onNoModel[\\s\\S]{0,160}(callTool|same evidence|same search)" }
      ],
      "forbidden": [
        { "category": "safety", "label": "does not frame as generic chatbot", "pattern": "generic chatbot|just add a chatbot" },
        { "category": "safety", "label": "does not rely only on toolChoice", "pattern": "toolChoice[^.]{0,80}(is enough|solves grounding)" }
      ]
    },
    {
      "id": "public-site-qa-identity",
      "surface": "site-assistant",
      "prompt": "If a visitor asks 'are you Edgekit or Gemma?', what should the assistant say?",
      "required": [
        { "category": "identity", "label": "separates assistant and model identity", "pattern": "assistant identity[\\s\\S]{0,180}(model|runtime|inference)|model[\\s\\S]{0,180}assistant identity" },
        { "category": "identity", "label": "mentions configured identity", "pattern": "configured identity|agentIdentity|developer configured" },
        { "category": "runtime", "label": "mentions Edgekit runtime separately", "pattern": "Edgekit[\\s\\S]{0,120}(runtime|component|widget|powers)" },
        { "category": "safety", "label": "forbids model-provider authorship claims", "pattern": "do not|should not|must not" }
      ],
      "forbidden": [
        { "category": "identity", "label": "does not say the assistant is Gemma", "pattern": "I am Gemma|created by the Gemma team" }
      ]
    }
  ]
}
