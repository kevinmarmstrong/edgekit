{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@kevinmarmstrong/edgekit": ["packages/core/src/index.ts"],
      "@kevinmarmstrong/edgekit/lite": ["packages/core/src/lite.ts"],
      "@kevinmarmstrong/edgekit-agui": ["packages/agui/src/index.ts"],
      "@kevinmarmstrong/edgekit-governance": ["packages/governance/src/index.ts"],
      "@kevinmarmstrong/edgekit-knowledge": ["packages/knowledge/src/index.ts"],
      "@kevinmarmstrong/edgekit-mcp": ["packages/mcp/src/index.ts"],
      "@kevinmarmstrong/edgekit-skills": ["packages/skills/src/index.ts"],
      "@kevinmarmstrong/edgekit-ui": ["packages/ui/src/index.ts"],
      "@kevinmarmstrong/edgekit-ui/lite": ["packages/ui/src/lite.ts"],
      "@kevinmarmstrong/edgekit-react": ["packages/react/src/index.ts"]
    }
  }
}
